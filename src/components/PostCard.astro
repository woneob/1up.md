---
import { Picture } from 'astro:assets';
import PostMeta from '~/components/PostMeta.astro';
import PostTags from '~/components/PostTags.astro';
import ViewCount from '~/components/ViewCount.astro';
import { formatDate } from '~/utils/formatDate';

const { post, showCover = false, seq = null } = Astro.props;
const seqLabel = seq != null ? String(seq).padStart(2, '0') : null;
---

<article class:list={['postCard', { 'postCard--indexed': seqLabel != null }]}>
  {showCover && post.cover && (
    <figure class="cover">
      <Picture
        src={post.cover}
        width={960}
        height={320}
        alt={post.title}
        class="cover"
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        fit="cover"
        widths={[320, 640, 1000]}
        sizes="auto"
        loading="lazy"
      />
    </figure>
  )}

  {seqLabel != null ? (
    <div class="cardGrid">
      <div class="cardSeq">
        <span class="cardSeqNum">{seqLabel}</span>
        <dl class="postMeta cardSeqMeta">
          <div class="postMetaItem" data-type="published">
            <dt>Published</dt>
            <dd>
              <time datetime={post.pubDate}>{formatDate(post.pubDate)}</time>
            </dd>
          </div>
          {post.stats && (
            <div class="postMetaItem" data-type="readingTime">
              <dt>Reading time</dt>
              <dd>
                <time datetime={`PT${Math.ceil(post.stats.minutes)}M`}>{post.stats.text}</time>
              </dd>
            </div>
          )}
          <ViewCount slug={post.slug} />
        </dl>
      </div>

      <div class="cardMain">
        <h2>
          <a href={`/${post.slug}`}>
            <span>{post.title}</span>
          </a>
        </h2>
        <div class="postBody">
          <p>{post.description}</p>
        </div>
      </div>

      <div class="cardTags">
        <PostTags tags={post.tags} />
      </div>
    </div>
  ) : (
    <Fragment>
      <h2>
        <a href={`/${post.slug}`}>
          <span>{post.title}</span>
        </a>
      </h2>

      <PostMeta pubDate={post.pubDate} stats={post.stats} slug={post.slug} />

      <div class="postBody">
        <p>{post.description}</p>
      </div>

      <PostTags tags={post.tags} />
    </Fragment>
  )}
</article>
