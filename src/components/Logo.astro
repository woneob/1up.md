---
const { siteName, description, layoutType } = Astro.props;
const Logo = layoutType === 'main' ? 'h1' : 'div';
---

<Logo class="logo" transition:persist>
  <a href="/">
    <span class="brand" role="img" aria-label={siteName + ' 로고'}>
      <img src="/images/1up.png" alt="" aria-hidden="true">
      <span class="siteName">{siteName}</span>
    </span>
    <span class="tagline">{description}</span>
  </a>
</Logo>
