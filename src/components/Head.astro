---
import { ClientRouter } from 'astro:transitions';
import globalCssUrl from '~/styles/global.scss?url';
import site from '~/data/site.config.yml';
import JsonLd from '~/components/JsonLd.astro';
import { baseGraph } from '~/utils/jsonld.js';
const { title, description, robots, jsonLd } = Astro.props;
// 베이스 노드(WebSite/Person/로고)를 전 페이지에 깔고 페이지별 노드를 합친다.
const graph = [...baseGraph(), ...(jsonLd ?? [])];
const canonicalPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonicalURL = new URL(canonicalPath, Astro.site);
---

<head>
  <meta charset="utf-8" />
  <title>{title}</title>

  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />

  <link rel="preload" href={globalCssUrl} as=style />
  <link rel="stylesheet" href={globalCssUrl} />

  {robots && (
    <meta name="robots" content={robots} />
  )}

  {site.author?.name && (
    <meta name="author" content={site.author.name} />
  )}

  {site.themeColor && (
    <meta name="theme-color" content={site.themeColor} />
  )}

  {site.siteIcons.map((item) => (
    <link
      rel={item.rel.join(' ')}
      href={item.href}
      type={item.type} />
  ))}

  <link
    rel="canonical"
    href={canonicalURL} />

  <link
    rel="manifest"
    href="/manifest.json"
    type="application/manifest+json">

  <link
    rel="alternate"
    type="application/rss+xml"
    title={'RSS feed for ' + site.siteName}
    href={new URL('rss.xml', Astro.site)} />

  <link rel="author" href="/humans.txt" />

  <JsonLd graph={graph} />

  {/* dev에서는 ClientRouter의 트랜지션 스왑이 SCSS HMR과 충돌해 이전 CSS가 남아 깜빡이므로 프로덕션 빌드에서만 렌더링. ClientRouter는 배포 사이트의 SPA 네비게이션 헤더 플리커 방지용이라 dev에 필요 없음. */}
  {import.meta.env.PROD && <ClientRouter />}
</head>
