---
import site from '~/data/site.config.yml';
import { logoAscii } from '~/utils/logoAscii.js';

const buildTime = import.meta.env.BUILD_TIME;
const date = buildTime ? new Date(buildTime) : new Date();

const time = new Intl.DateTimeFormat('en-US', {
  hour: 'numeric',
  minute: '2-digit',
  hour12: true,
}).format(date);

const day = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

const indentedLogo = logoAscii.replace(/^/gm, ' ');

const banner = `
<!--
${indentedLogo}

 ${site.siteName} - ${site.tagline}
 Last updated at ${time}, ${day}
-->
`;
---

<Fragment set:html={banner} />
