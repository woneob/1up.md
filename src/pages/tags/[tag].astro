---
import DefaultLayout from '~/layouts/DefaultLayout.astro';
import PostCard from '~/components/PostCard.astro';
import { getAllPosts } from '~/utils/posts.js';
import { collectionGraph } from '~/utils/jsonld.js';

export function getStaticPaths() {
  const tagSet = new Set();
  getAllPosts().forEach(({ frontmatter }) => {
    (frontmatter.tags ?? []).forEach(tag => tagSet.add(tag));
  });
  return Array.from(tagSet).map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;

const filtered = getAllPosts()
  .filter(({ frontmatter }) => (frontmatter.tags ?? []).includes(tag))
  .map(({ slug, frontmatter, stats }) => ({
    slug,
    title: frontmatter.title || slug,
    description: frontmatter.description || '',
    pubDate: frontmatter.pubDate || '',
    tags: frontmatter.tags || [],
    stats,
  }));

const title = `Tag: ${tag}`;
const description = `"${tag}" 태그를 가진 게시물`;

const jsonLd = collectionGraph({
  url: new URL(`tags/${tag}`, Astro.site).href,
  name: title,
  description,
  slugs: filtered.map(p => p.slug),
  breadcrumb: [
    { name: 'Home', item: new URL('/', Astro.site).href.replace(/\/$/, '') },
    { name: 'Tags', item: new URL('tags', Astro.site).href },
    { name: `#${tag}` },
  ],
});
---

<DefaultLayout {title} {description} {jsonLd}>
  <h2>#{tag}</h2>

  {filtered.length === 0 ? (
    <p>해당 태그의 게시물이 없습니다.</p>
  ) : (
    <div class="articles">
      {filtered.map(post => (
        <PostCard {post} />
      ))}
    </div>
  )}
</DefaultLayout>
