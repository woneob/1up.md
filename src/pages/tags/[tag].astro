---
import DefaultLayout from '~/layouts/DefaultLayout.astro';
import PostCard from '~/components/PostCard.astro';
import { getAllPosts } from '~/utils/posts.js';

export function getStaticPaths() {
  const tagSet = new Set();
  getAllPosts().forEach(({ frontmatter }) => {
    (frontmatter.tags ?? []).forEach(tag => tagSet.add(tag));
  });
  return Array.from(tagSet).map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;

const filtered = getAllPosts()
  .filter(({ frontmatter }) => (frontmatter.tags ?? []).includes(tag))
  .map(({ slug, frontmatter, stats }) => ({
    slug,
    title: frontmatter.title || slug,
    description: frontmatter.description || '',
    pubDate: frontmatter.pubDate || '',
    tags: frontmatter.tags || [],
    stats,
  }));

const title = `Tag: ${tag}`;
const description = `"${tag}" 태그를 가진 게시물`;
---

<DefaultLayout {title} {description}>
  <h2>#{tag}</h2>

  {filtered.length === 0 ? (
    <p>해당 태그의 게시물이 없습니다.</p>
  ) : (
    <div class="articles">
      {filtered.map(post => (
        <PostCard {post} />
      ))}
    </div>
  )}
</DefaultLayout>
