---
import DefaultLayout from '~/layouts/DefaultLayout.astro';
import site from '~/data/site.config.yml';
import PostCard from '~/components/PostCard.astro';
import { getAllPosts } from '~/utils/posts.js';

const all = getAllPosts();
const total = all.length;
const posts = all.map(({ slug, frontmatter, cover, stats }, i) => ({
  slug,
  title: frontmatter.title,
  description: frontmatter.description,
  pubDate: frontmatter.pubDate,
  tags: frontmatter.tags,
  cover,
  stats,
  seq: total - i, // 최신글이 가장 큰 번호, 가장 오래된 글이 1
}));
---

<DefaultLayout>
  <div class="symbol">
    <h1>{site.siteName}</h1>
    <p class="tagline">{site.tagline}</p>
  </div>

  <div class="articles">
    {posts.map((post, i) => (
      <PostCard {post} showCover seq={post.seq} eager={i === 0} />
    ))}

    {posts.length === 0 && (
      <p class="empty">등록된 게시물이 없습니다.</p>
    )}
  </div>
</DefaultLayout>
