---
import { Picture } from 'astro:assets';
import DefaultLayout from '~/layouts/DefaultLayout.astro';
import PostMeta from '~/components/PostMeta.astro';
import PostTags from '~/components/PostTags.astro';
import PostToc from '~/components/PostToc.astro';
import { getAllPosts, getPostBySlug } from '~/utils/posts.js';

export function getStaticPaths() {
  return getAllPosts().map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug);

if (!post) {
  throw new Error(`포스트를 찾을 수 없습니다: ${slug}`);
}

const { title, description, pubDate, tags, robots } = post.frontmatter;
const multilineTitle = title.includes('\n');
const Content = post.module.default;
const stats = post.stats;
const headings = typeof post.module.getHeadings === 'function' ? post.module.getHeadings() : [];
const cover = post.cover;
---

<DefaultLayout {title} {description} {robots} pageId="post">
  <article>
    <header class="postHeader">
      <h1 class:list={[{ multilineTitle }]}>{title}</h1>
      <PostMeta {pubDate} {stats} {slug} increment />
      <PostTags {tags} />
    </header>
    <div class="postContent">
      {cover && (
        <figure class="postCover">
          <Picture
            src={cover}
            width={940}
            height={382}
            alt={title}
            formats={['avif', 'webp']}
            fallbackFormat="webp"
            fit="cover"
            widths={[640, 940, 1600]}
            sizes="(min-width: 960px) 940px, 100vw"
            loading="eager"
          />
        </figure>
      )}
      <PostToc {headings} />
      <div class="postBody">
        <Content />
      </div>
    </div>
  </article>
</DefaultLayout>
